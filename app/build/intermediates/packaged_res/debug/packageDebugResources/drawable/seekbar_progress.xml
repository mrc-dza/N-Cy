<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:id="@android:id/background" android:gravity="center_vertical">
        <shape android:shape="rectangle">
            <corners android:radius="1dp" />
            <solid android:color="#555555" /> <size android:height="2dp" />
        </shape>
    </item>

    <item android:id="@android:id/progress" android:gravity="center_vertical">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="1dp" />
                <solid android:color="#FFFFFF" /> <size android:height="2dp" />
            </shape>
        </clip>
    </item>

</layer-list>