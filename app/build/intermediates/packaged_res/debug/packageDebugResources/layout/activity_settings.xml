<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/txtTituloPrincipalSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configuraciones"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="16dp"/>

    <include layout="@layout/item_config_switch" android:id="@+id/cardTema" />
    <include layout="@layout/item_config_switch" android:id="@+id/cardVibracion" />
    <include layout="@layout/item_config_switch" android:id="@+id/cardBarra" />
    <include layout="@layout/item_config_switch" android:id="@+id/cardAutoMayusculas" />
    <include layout="@layout/item_config_slider" android:id="@+id/cardAltura" />
    
</LinearLayout>