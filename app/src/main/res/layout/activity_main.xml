<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/raizMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="40dp">

          
            <TextView
                android:id="@+id/txtTituloMain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N-Cy"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/txtSubtituloMain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privado, rápido y totalmente tuyo."
                android:textSize="13sp"
                android:layout_marginBottom="40dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/circuloPaso1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="✓"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <View
                        android:id="@+id/lineaProgreso"
                        android:layout_width="2dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/circuloPaso2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="2"
                        android:textSize="11sp"
                        android:gravity="center" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <LinearLayout
                        android:id="@+id/cardPaso1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tituloPaso1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Habilitar en Ajustes"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/subtextoPaso1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Activa N-Cy en los ajustes del sistema"
                            android:textSize="12sp"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:id="@+id/btnPaso1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Abrir Ajustes →"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingLeft="16dp"
                            android:paddingRight="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardPaso2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tituloPaso2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Seleccionar N-Cy"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/subtextoPaso2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Elige N-Cy como teclado activo"
                            android:textSize="12sp"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:id="@+id/btnPaso2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendiente"
                            android:textSize="12sp"
                            android:paddingLeft="16dp"
                            android:paddingRight="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"/>

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bannerActivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/iconoBanner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textSize="16sp"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/textoBanner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="N-Cy está activo y listo"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/btnConfiguraciones"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|top"
            android:layout_margin="16dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" 
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:src="@drawable/ic_engrane"
            android:contentDescription="Configuraciones" />
    </FrameLayout>
</ScrollView>